# Optional: professor API base URL, e.g. https://api.example.edu/cs201
COURSE_API_BASE_URL=

# Optional: API key if professor API requires authentication
COURSE_API_KEY=

# Optional: week progress adapter source
WEEK_PROGRESS_SOURCE=local-tasks

# Optional: ed forum progress endpoint (reserved for future integration)
WEEK_PROGRESS_ED_API_BASE_URL=
WEEK_PROGRESS_ED_API_TOKEN=

# Optional: course pages progress endpoint (reserved for future integration)
WEEK_PROGRESS_COURSE_PAGES_API_BASE_URL=
WEEK_PROGRESS_COURSE_PAGES_API_TOKEN=

# Local portal login. Development falls back to cs201/cs201 when unset.
# Optional multi-user format: username:password,another:password
CS201_PORTAL_USERS=
CS201_PORTAL_USERNAME=
CS201_PORTAL_PASSWORD=
CS201_PORTAL_SESSION_SECRET=
# Set only for an HTTP-only VM deployment where HTTPS is unavailable.
CS201_ALLOW_INSECURE_COOKIES=
# Optional comma-separated local portal users that can only view static resources.
CS201_RESTRICTED_LOCAL_USERS=

# Optional: teacher-site SSO. Portal redirects users to the teacher site and
# exchanges the returned code for a short-lived teacher access token.
CS201_PORTAL_BASE_URL=http://localhost:3000
TEACHER_SSO_BASE_URL=http://repolab.colab.duke.edu:8005
TEACHER_SSO_CLIENT_ID=cs201-portal
TEACHER_SSO_CLIENT_SECRET=
TEACHER_SESSION_ENCRYPTION_SECRET=

# Optional comma-separated portal usernames allowed to edit local portal content at /admin.
CS201_ADMIN_USERS=

# Optional e2e login override. Defaults to the development fallback when unset.
E2E_PORTAL_USERNAME=
E2E_PORTAL_PASSWORD=

# Optional: upstream CS201 quiz proxy. Values are used server-side only.
CS201_QUIZ_BASE_URL=http://10.200.20.79:8005
CS201_QUIZ_USER_MAP=

# Optional: upstream BK/BQ reflection proxy. Values are used server-side only.
CS201_BK_BASE_URL=http://10.200.20.79:8000
CS201_BK_USER_MAP=
